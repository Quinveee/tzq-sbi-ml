########################################
# Executable and arguments
########################################
executable              = scripts/run_test.sh
arguments               = $(tarball_name)

########################################
# File transfer
########################################
should_transfer_files   = YES
when_to_transfer_output = ON_EXIT_OR_EVICT
transfer_input_files    = $(tarball)
transfer_output_files   = $(data_run_dir_base)

########################################
# Resources
########################################
request_cpus    = 4
request_memory  = 1GB
request_disk    = 1GB
request_gpus    = 1

# Require V100 GPU
requirements = regexp("V100", TARGET.GPUs_DeviceName)

########################################
# Environment
########################################
environment = "ENV=$(ENV);PYTHONPATH=$(PWD)"
# If you want WANDB passed:
# environment = "ENV=$(ENV);PYTHONPATH=$(PWD);WANDB_API_KEY=$(WANDB_API_KEY)"

# Alternative (uncomment if preferred)
# getenv = True

########################################
# Logging
########################################
output  = logs/$(Cluster).$(Process).out
error   = logs/$(Cluster).$(Process).err
log     = logs/$(Cluster).$(Process).log

########################################
# ClassAds (description_addition)
########################################
+UseOS       = "el9"
+JobCategory = "short"

########################################
# Queue
########################################
queue